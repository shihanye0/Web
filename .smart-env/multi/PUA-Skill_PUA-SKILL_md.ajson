、验证、自检":[368,372],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#任务生命周期行为框架#执行中 — 简化、验证、自检#{1}":[369,372],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#任务生命周期行为框架#交付时 — 用证据说话":[373,384],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#任务生命周期行为框架#交付时 — 用证据说话#{1}":[374,384],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#任务生命周期行为框架#交付后 — 复盘沉淀":[385,391],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#任务生命周期行为框架#交付后 — 复盘沉淀#{1}":[386,391],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#体面的退出":[392,397],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#体面的退出#{1}":[394,397],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#任务完成反馈（每次主要任务交付后）":[398,420],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#任务完成反馈（每次主要任务交付后）#{1}":[400,420],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#搭配使用":[421,429],"#PUA 我们不养闲 Agent，一个提高agent积极性的skill。#搭配使用#{1}":[423,429]},"outlinks":[],"metadata":{"name":"pua","description":"Use for PUA/try-harder productivity coaching when the user expresses frustration, repeated failure, quality complaint, passive behavior, says retry/change approach/don't give up, asks for evidence/completion check/test before done, or wants Ding-style workplace reminders. Triggers include: try harder, stop giving up, figure it out, again??, why still failing, change approach, no evidence, run tests, done without proof, 换个方法, 再试试, 别摆烂, 别偷懒, 为什么还不行, 又错了, 证据呢, 没跑测试别说完成, 验收, 闭环, 自嗨, 置身钉外, 无招, 老板体感. Do not use for calm first-attempt requests.","license":"MIT"},"task_lines":[322,323,324,325,326,327,328],"tasks":{"incomplete":{"all":[322,323,324,325,326,327,328],"top":[322,323,324,325,326,327,328]}},"codeblock_ranges":[[62,64],[98,104],[417,419]],"key":"PUA-Skill/PUA-SKILL.md"},
